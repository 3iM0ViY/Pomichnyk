			"contents": "{% extends \"base.html\" %}\n{% load static %}\n\n{% block title %}{{ map.name }}{% endblock %}\n\n{% block content %}\n<div class=\"map-detail\">\n\t<section class=\"map-hero\">\n\t\t<div class=\"map-title-block\">\n\t\t\t<h1 class=\"map-title\">{{ map.name }}</h1>\n\t\t\t<div class=\"map-badges\">\n\t\t\t\t{% if map.is_in_pool %}\n\t\t\t\t\t<span class=\"badge badge-active\">В ротації</span>\n\t\t\t\t{% else %}\n\t\t\t\t\t<span class=\"badge badge-removed\">На кладовищі історії</span>\n\t\t\t\t{% endif %}\n\t\t\t\t<span class=\"badge badge-views\">\n\t\t\t\t\t{{ map.views }} переглядів\n\t\t\t\t</span>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\n\t<section class=\"map-hero-grid\">\n\t\t<div class=\"map-preview\">\n\t\t\t<img src=\"{{ map.image.url }}\" alt=\"{{ map.name }}\">\n\t\t</div>\n\n\t\t<aside class=\"map-strategies\">\n\t\t\t<h2>Страти</h2>\n\t\t\t<div class=\"strategy-list\">\n\t\t\t\t{% for strat in strategies %}\n\t\t\t\t\t{% if strat.is_active %}\n\t\t\t\t\t\t<a href=\"{{ strat.get_absolute_url }}\" class=\"strategy-card\">\n\t\t\t\t\t\t\t<div class=\"strategy-top\">\n\t\t\t\t\t\t\t\t<span class=\"strategy-name\">{{ strat.name }}</span>\n\t\t\t\t\t\t\t\t<span class=\"strategy-side\">\n\t\t\t\t\t\t\t\t\t{% if strat.side == \"T\" %}\n\t\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/t_logo.svg' %}\" alt=\"T side\">\n\t\t\t\t\t\t\t\t\t{% else %}\n\t\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/ct_logo.svg' %}\" alt=\"CT side\">\n\t\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t<div class=\"strategy-meta\">\n\t\t\t\t\t\t\t\t<span>{{ strat.likes }} вподобайок</span>\n\t\t\t\t\t\t\t\t{% if strat.is_active %}\n\t\t\t\t\t\t\t\t\t<span class=\"dot active\"></span> активна\n\t\t\t\t\t\t\t\t{% else %}\n\t\t\t\t\t\t\t\t\t<span class=\"dot inactive\"></span> архівовано\n\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t<div class=\"strategy-author\">\n\t\t\t\t\t\t\t\tавтор: {{ strat.created_by }}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t{% endif %}\n\t\t\t\t{% empty %}\n\t\t\t\t\t<p class=\"muted\">Напишіть першу стратку.</p>\n\t\t\t\t{% endfor %}\n\t\t\t</div>\n\t\t\t{% if strategies|length >= 10 %}\n\t\t\t\t<button class=\"btn btn-small\">Переглянути всі</button>\n\t\t\t{% endif %}\n\t\t</aside>\n\t</section>\n\n\t<section class=\"lineups-section\">\n\t\t<div class=\"lineups-header\">\n\t\t\t<h2>Лайнапи гранат</h2>\n\n\t\t\t<div class=\"lineup-filters\" aria-label=\"Фільтр гранат\">\n\t\t\t\t<button class=\"lineup-filter active\" type=\"button\" data-filter=\"all\" aria-label=\"Усі гранати\">\n\t\t\t\t\t<span>Усі</span>\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"smoke\" aria-label=\"Смоки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/smokegrenade.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"molotov\" aria-label=\"Моліки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/molotov.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"flash\" aria-label=\"Флешки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/flashbang.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"he\" aria-label=\"ХаЕ\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/hegrenade.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"decoy\" aria-label=\"Декої\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/decoy.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"lineups-grid\">\n\t\t\t{% for lineup in lineups %}\n\t\t\t\t<article class=\"lineup-card lineup-{{ lineup.utility }}\">\n\t\t\t\t\t<div class=\"lineup-media lineup-expand-trigger\">\n\t\t\t\t\t\t<div class=\"lineup-slider\">\n\t\t\t\t\t\t\t<div class=\"lineup-track\">\n\t\t\t\t\t\t\t\t{% for img in lineup.slide.all|dictsort:\"created_at\" %}\n\t\t\t\t\t\t\t\t\t<div class=\"lineup-slide\">\n\t\t\t\t\t\t\t\t\t\t<img src=\"{{ img.img.url }}\" alt=\"{{ lineup.title }}\">\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t{% empty %}\n\t\t\t\t\t\t\t\t\t<div class=\"placeholder\">\n\t\t\t\t\t\t\t\t\t\tНема картінок\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t{% endfor %}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t{% if lineup.slide.all|length > 1 %}\n\t\t\t\t\t\t\t<button class=\"slider-btn slider-prev\" type=\"button\" aria-label=\"Попереднє зображення\">\n\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/double_arrows.svg' %}\" alt=\"\">\n\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t<button class=\"slider-btn slider-next\" type=\"button\" aria-label=\"Наступне зображення\">\n\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/double_arrows.svg' %}\" alt=\"\">\n\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"lineup-retake-ribbon\">\n\t\t\t\t\t\t<span>{{ lineup.title }}</span>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"lineup-info\">\n\t\t\t\t\t\t<div class=\"lineup-heading\">\n\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t<p class=\"muted\">{{ lineup.description }}</p>\n\t\t\t\t\t\t\t\t{% if lineup.comment %}\n\t\t\t\t\t\t\t\t\t<p class=\"muted comment\">{{ lineup.comment }}</p>\n\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"utility-icon\">\n\t\t\t\t\t\t\t\t{% if lineup.utility == \"smoke\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/smokegrenade.svg' %}\" alt=\"Smoke\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"molotov\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/molotov.svg' %}\" alt=\"Molotov\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"flash\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/flashbang.svg' %}\" alt=\"Flashbang\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"he\" %}\n\t\t\t\t\t\t\t\t\t