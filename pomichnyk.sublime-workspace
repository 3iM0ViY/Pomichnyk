			"contents": "{% extends \"base.html\" %}\n{% load static %}\n\n{% block title %}{{ map.name }}{% endblock %}\n\n{% block content %}\n<div class=\"map-detail\">\n\t<section class=\"map-hero\">\n\t\t<div class=\"map-title-block\">\n\t\t\t<h1 class=\"map-title\">{{ map.name }}</h1>\n\t\t\t<div class=\"map-badges\">\n\t\t\t\t{% if map.is_in_pool %}\n\t\t\t\t\t<span class=\"badge badge-active\">В ротації</span>\n\t\t\t\t{% else %}\n\t\t\t\t\t<span class=\"badge badge-removed\">На кладовищі історії</span>\n\t\t\t\t{% endif %}\n\t\t\t\t<span class=\"badge badge-views\">\n\t\t\t\t\t{{ map.views }} переглядів\n\t\t\t\t</span>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\n\t<section class=\"map-hero-grid\">\n\t\t<div class=\"map-preview\">\n\t\t\t<img src=\"{{ map.image.url }}\" alt=\"{{ map.name }}\">\n\t\t</div>\n\n\t\t<aside class=\"map-strategies\">\n\t\t\t<h2>Страти</h2>\n\t\t\t<div class=\"strategy-list\">\n\t\t\t\t{% for strat in strategies %}\n\t\t\t\t\t{% if strat.is_active %}\n\t\t\t\t\t\t<a href=\"{{ strat.get_absolute_url }}\" class=\"strategy-card\">\n\t\t\t\t\t\t\t<div class=\"strategy-top\">\n\t\t\t\t\t\t\t\t<span class=\"strategy-name\">{{ strat.name }}</span>\n\t\t\t\t\t\t\t\t<span class=\"strategy-side\">\n\t\t\t\t\t\t\t\t\t{% if strat.side == \"T\" %}\n\t\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/t_logo.svg' %}\" alt=\"T side\">\n\t\t\t\t\t\t\t\t\t{% else %}\n\t\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/ct_logo.svg' %}\" alt=\"CT side\">\n\t\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t<div class=\"strategy-meta\">\n\t\t\t\t\t\t\t\t<span>{{ strat.likes }} вподобайок</span>\n\t\t\t\t\t\t\t\t{% if strat.is_active %}\n\t\t\t\t\t\t\t\t\t<span class=\"dot active\"></span> активна\n\t\t\t\t\t\t\t\t{% else %}\n\t\t\t\t\t\t\t\t\t<span class=\"dot inactive\"></span> архівовано\n\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t<div class=\"strategy-author\">\n\t\t\t\t\t\t\t\tавтор: {{ strat.created_by }}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t{% endif %}\n\t\t\t\t{% empty %}\n\t\t\t\t\t<p class=\"muted\">Напишіть першу стратку.</p>\n\t\t\t\t{% endfor %}\n\t\t\t</div>\n\t\t\t{% if strategies|length >= 10 %}\n\t\t\t\t<button class=\"btn btn-small\">Переглянути всі</button>\n\t\t\t{% endif %}\n\t\t</aside>\n\t</section>\n\n\t<section class=\"lineups-section\">\n\t\t<div class=\"lineups-header\">\n\t\t\t<h2>Лайнапи гранат</h2>\n\n\t\t\t<div class=\"lineup-filters\" aria-label=\"Фільтр гранат\">\n\t\t\t\t<button class=\"lineup-filter active\" type=\"button\" data-filter=\"all\" aria-label=\"Усі гранати\">\n\t\t\t\t\t<span>Усі</span>\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"smoke\" aria-label=\"Смоки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/smokegrenade.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"molotov\" aria-label=\"Моліки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/molotov.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"flash\" aria-label=\"Флешки\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/flashbang.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"he\" aria-label=\"ХаЕ\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/hegrenade.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t\t<button class=\"lineup-filter\" type=\"button\" data-filter=\"decoy\" aria-label=\"Декої\">\n\t\t\t\t\t<img src=\"{% static 'static_img/icons/decoy.svg' %}\" alt=\"\">\n\t\t\t\t</button>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"lineups-grid\">\n\t\t\t{% for lineup in lineups %}\n\t\t\t\t<article class=\"lineup-card lineup-{{ lineup.utility }}\">\n\t\t\t\t\t<div class=\"lineup-media lineup-expand-trigger\">\n\t\t\t\t\t\t<div class=\"lineup-slider\">\n\t\t\t\t\t\t\t<div class=\"lineup-track\">\n\t\t\t\t\t\t\t\t{% for img in lineup.slide.all|dictsort:\"created_at\" %}\n\t\t\t\t\t\t\t\t\t<div class=\"lineup-slide\">\n\t\t\t\t\t\t\t\t\t\t<img src=\"{{ img.img.url }}\" alt=\"{{ lineup.title }}\">\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t{% empty %}\n\t\t\t\t\t\t\t\t\t<div class=\"placeholder\">\n\t\t\t\t\t\t\t\t\t\tНема картінок\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t{% endfor %}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t{% if lineup.slide.all|length > 1 %}\n\t\t\t\t\t\t\t<button class=\"slider-btn slider-prev\" type=\"button\" aria-label=\"Попереднє зображення\">\n\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/double_arrows.svg' %}\" alt=\"\">\n\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t<button class=\"slider-btn slider-next\" type=\"button\" aria-label=\"Наступне зображення\">\n\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/double_arrows.svg' %}\" alt=\"\">\n\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"lineup-retake-ribbon\">\n\t\t\t\t\t\t<span>{{ lineup.title }}</span>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"lineup-info\">\n\t\t\t\t\t\t<div class=\"lineup-heading\">\n\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t<p class=\"muted\">{{ lineup.description }}</p>\n\t\t\t\t\t\t\t\t{% if lineup.comment %}\n\t\t\t\t\t\t\t\t\t<p class=\"muted comment\">{{ lineup.comment }}</p>\n\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"utility-icon\">\n\t\t\t\t\t\t\t\t{% if lineup.utility == \"smoke\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/smokegrenade.svg' %}\" alt=\"Smoke\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"molotov\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/molotov.svg' %}\" alt=\"Molotov\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"flash\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/flashbang.svg' %}\" alt=\"Flashbang\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"he\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/hegrenade.svg' %}\" alt=\"HE Grenade\">\n\t\t\t\t\t\t\t\t{% elif lineup.utility == \"decoy\" %}\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/decoy.svg' %}\" alt=\"Decoy\">\n\t\t\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"lineup-meta\">\n\t\t\t\t\t\t\t<span>Звідки: {{ lineup.throw_from }}</span>\n\t\t\t\t\t\t\t<span>Куди: {{ lineup.land_at }}</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t{% if lineup.video_url %}\n\t\t\t\t\t\t\t<a href=\"{{ lineup.get_embed_url }}\" target=\"_blank\">\n\t\t\t\t\t\t\t\tВідео\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t\t<div class=\"lineup-footer\">\n\t\t\t\t\t\t\t<div class=\"lineup-votes\" data-vote-url=\"{% url 'home:lineup_vote' lineup.pk %}\">\n\t\t\t\t\t\t\t\t<button class=\"vote-btn vote-down\" type=\"button\" data-vote=\"down\">\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/chatwheel_negative.svg' %}\" alt=\"Мінус\">\n\t\t\t\t\t\t\t\t</button>\n\n\t\t\t\t\t\t\t\t<span class=\"likes-count\">{{ lineup.likes }}</span>\n\n\t\t\t\t\t\t\t\t<button class=\"vote-btn vote-up\" type=\"button\" data-vote=\"up\">\n\t\t\t\t\t\t\t\t\t<img src=\"{% static 'static_img/icons/chatwheel_affirmative.svg' %}\" alt=\"Плюс\">\n\t\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t<span>автор: {{ lineup.created_by }}</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</article>\n\t\t\t{% empty %}\n\t\t\t\t<p class=\"muted\">Додайте свою першу гранатку.</p>\n\t\t\t{% endfor %}\n\t\t</div>\n\t</section>\n\n\t<div class=\"lineup-modal\" id=\"lineupModal\" aria-hidden=\"true\">\n\t\t<div class=\"lineup-modal-backdrop\"></div>\n\n\t\t<div class=\"lineup-modal-content\">\n\t\t\t<button class=\"lineup-modal-close\" type=\"button\" aria-label=\"Закрити\">\n\t\t\t\t×\n\t\t\t</button>\n\n\t\t\t<div class=\"lineup-modal-inner\"></div>\n\t\t</div>\n\t</div>\n</div>\n{% endblock %}\n\n{% block scripts %}\n<script>\n\tdocument.querySelectorAll(\".lineup-filter\").forEach(filterBtn => {\n\t\tfilterBtn.addEventListener(\"click\", () => {\n\t\t\tconst filter = filterBtn.dataset.filter;\n\n\t\t\tdocument.querySelectorAll(\".lineup-filter\").forEach(btn => {\n\t\t\t\tbtn.classList.remove(\"active\");\n\t\t\t});\n\n\t\t\tfilterBtn.classList.add(\"active\");\n\n\t\t\tdocument.querySelectorAll(\".lineup-card\").forEach(card => {\n\t\t\t\tif (filter === \"all\") {\n\t\t\t\t\tcard.classList.remove(\"is-hidden\");\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t\tcard.classList.toggle(\n\t\t\t\t\t\"is-hidden\", !card.classList.contains(`lineup-${filter}`)\n\t\t\t\t);\n\t\t\t});\n\t\t});\n\t});\n</script>\n<script>\n\tfunction getCookie(name) {\n\t\tconst value = `; ${document.cookie}`;\n\t\tconst parts = value.split(`; ${name}=`);\n\t\tif (parts.length === 2) {\n\t\t\treturn parts.pop().split(\";\").shift();\n\t\t}\n\t}\n\n\t/* =========================\n\t\tVoting\n\t========================= */\n\tdocument.addEventListener(\"click\", async event => {\n\t\tconst button = event.target.closest(\".vote-btn\");\n\t\tif (!button) return;\n\n\t\tconst voteBox = button.closest(\".lineup-votes\");\n\t\tif (!voteBox) return;\n\n\t\tevent.preventDefault();\n\t\tevent.stopPropagation();\n\n\t\tconst url = voteBox.dataset.voteUrl;\n\t\tconst formData = new FormData();\n\t\tformData.append(\"vote\", button.dataset.vote);\n\n\t\tconst response = await fetch(url, {\n\t\t\tmethod: \"POST\",\n\t\t\theaders: {\n\t\t\t\t\"X-CSRFToken\": getCookie(\"csrftoken\"),\n\t\t\t},\n\t\t\tbody: formData,\n\t\t});\n\n\t\tif (!response.ok) return;\n\n\t\tconst data = await response.json();\n\n\t\tdocument.querySelectorAll(`.lineup-votes[data-vote-url=\"${url}\"]`).forEach(box => {\n\t\t\tconst count = box.querySelector(\".likes-count\");\n\n\t\t\tcount.textContent = data.likes;\n\t\t\tcount.classList.remove(\"bump-positive\", \"bump-negative\");\n\t\t\tvoid count.offsetWidth;\n\n\t\t\tcount.classList.add(\n\t\t\t\tdata.user_vote === -1\n\t\t\t\t\t? \"bump-negative\"\n\t\t\t\t\t: \"bump-positive\"\n\t\t\t);\n\n\t\t\tbox.querySelectorAll(\".vote-btn\").forEach(btn => {\n\t\t\t\tbtn.classList.remove(\"active\");\n\t\t\t});\n\n\t\t\tif (data.user_vote === 1) {\n\t\t\t\tbox.querySelector(\".vote-up\")?.classList.add(\"active\");\n\t\t\t}\n\t\t\tif (data.user_vote === -1) {\n\t\t\t\tbox.querySelector(\".vote-down\")?.classList.add(\"active\");\n\t\t\t}\n\t\t});\n\t});\n\n\t/* =========================\n\t\tCarousel\n\t========================= */\n\tfunction initLineupSlider(slider) {\n\t\tconst track = slider.querySelector(\".lineup-track\");\n\t\tif (!track) return;\n\t\tconst slides = slider.querySelectorAll(\".lineup-slide\");\n\t\tconst prevBtn = slider.querySelector(\".slider-prev\");\n\t\tconst nextBtn = slider.querySelector(\".slider-next\");\n\n\t\tlet index = 0;\n\t\tconst maxIndex = slides.length - 1;\n\n\t\tfunction updateSlider() {\n\t\t\ttrack.style.transform = `translateX(-${index * 100}%)`;\n\t\t\tif (prevBtn) {\n\t\t\t\tprevBtn.classList.toggle(\"disabled\", index === 0);\n\t\t\t}\n\t\t\tif (nextBtn) {\n\t\t\t\tnextBtn.classList.toggle(\"disabled\", index === maxIndex);\n\t\t\t}\n\t\t}\n\n\t\tif (nextBtn) {\n\t\t\tnextBtn.addEventListener(\"click\", event => {\n\t\t\t\tevent.stopPropagation();\n\t\t\t\tif (index < maxIndex) {\n\t\t\t\t\tindex++;\n\t\t\t\t\tupdateSlider();\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t\tif (prevBtn) {\n\t\t\tprevBtn.addEventListener(\"click\", event => {\n\t\t\t\tevent.stopPropagation();\n\t\t\t\tif (index > 0) {\n\t\t\t\t\tindex--;\n\t\t\t\t\tupdateSlider();\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\n\t\tupdateSlider();\n\t}\n\n\tdocument.querySelectorAll(\".lineup-media\").forEach(initLineupSlider);\n\n\t/* =========================\n\t\tLINEUP FULLSCREEN\n\t========================= */\n\tconst lineupModal = document.querySelector(\"#lineupModal\");\n\tconst lineupModalInner = lineupModal?.querySelector(\".lineup-modal-inner\");\n\tconst lineupModalClose = lineupModal?.querySelector(\".lineup-modal-close\");\n\tconst lineupModalBackdrop = lineupModal?.querySelector(\".lineup-modal-backdrop\");\n\tlet lineupScrollPosition = 0; // returning to the same spot\n\n\tfunction openLineupModal(card) {\n\t\tif (!lineupModal || !lineupModalInner) return;\n\n\t\tlineupScrollPosition = window.scrollY;\n\n\t\tconst clone = card.cloneNode(true);\n\n\t\tlineupModalInner.innerHTML = \"\";\n\t\tlineupModalInner.appendChild(clone);\n\n\t\tlineupModal.classList.add(\"active\");\n\t\tlineupModal.setAttribute(\"aria-hidden\", \"false\");\n\t\tdocument.body.classList.add(\"modal-open\");\n\n\t\tclone.querySelectorAll(\".lineup-media\").forEach(initLineupSlider);\n\t}\n\n\tfunction closeLineupModal() {\n\t\tif (!lineupModal || !lineupModalInner) return;\n\n\t\tlineupModal.classList.remove(\"active\");\n\t\tlineupModal.setAttribute(\"aria-hidden\", \"true\");\n\t\tdocument.body.classList.remove(\"modal-open\");\n\n\t\tlineupModalInner.innerHTML = \"\";\n\n\t\twindow.scrollTo({\n\t\t\ttop: lineupScrollPosition,\n\t\t\tbehavior: \"instant\"\n\t\t});\n\t}\n\n\tdocument.querySelectorAll(\".lineups-grid > .lineup-card\").forEach(card => {\n\t\tconst triggers = card.querySelectorAll(\".lineup-expand-trigger\");\n\t\ttriggers.forEach(trigger => {\n\t\t\ttrigger.addEventListener(\"click\", event => {\n\t\t\t\tevent.preventDefault();\n\t\t\t\tevent.stopPropagation();\n\n\t\t\t\topenLineupModal(card);\n\t\t\t});\n\t\t});\n\t});\n\n\tlineupModalClose?.addEventListener(\"click\", closeLineupModal);\n\tlineupModalBackdrop?.addEventListener(\"click\", closeLineupModal);\n\n\tdocument.addEventListener(\"keydown\", event => {\n\t\tif (event.key === \"Escape\") {\n\t\t\tcloseLineupModal();\n\t\t}\n\t});\n</script>\n{% endblock %}",
