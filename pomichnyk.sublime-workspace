lectorAll(\".lineup-filter\").forEach(filterBtn => {\n\t\tfilterBtn.addEventListener(\"click\", () => {\n\t\t\tconst filter = filterBtn.dataset.filter;\n\n\t\t\tdocument.querySelectorAll(\".lineup-filter\").forEach(btn => {\n\t\t\t\tbtn.classList.remove(\"active\");\n\t\t\t});\n\n\t\t\tfilterBtn.classList.add(\"active\");\n\n\t\t\tdocument.querySelectorAll(\".lineup-card\").forEach(card => {\n\t\t\t\tif (filter === \"all\") {\n\t\t\t\t\tcard.classList.remove(\"is-hidden\");\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t\tcard.classList.toggle(\n\t\t\t\t\t\"is-hidden\", !card.classList.contains(`lineup-${filter}`)\n\t\t\t\t);\n\t\t\t});\n\t\t});\n\t});\n</script>\n<script>\n\tfunction getCookie(name) {\n\t\tconst value = `; ${document.cookie}`;\n\t\tconst parts = value.split(`; ${name}=`);\n\t\tif (parts.length === 2) {\n\t\t\treturn parts.pop().split(\";\").shift();\n\t\t}\n\t}\n\n\t/* =========================\n\t\tVoting\n\t========================= */\n\tdocument.addEventListener(\"click\", async event => {\n\t\tconst button = event.target.closest(\".vote-btn\");\n\t\tif (!button) return;\n\n\t\tconst voteBox = button.closest(\".lineup-votes\");\n\t\tif (!voteBox) return;\n\n\t\tevent.preventDefault();\n\t\tevent.stopPropagation();\n\n\t\tconst url = voteBox.dataset.voteUrl;\n\t\tconst formData = new FormData();\n\t\tformData.append(\"vote\", button.dataset.vote);\n\n\t\tconst response = await fetch(url, {\n\t\t\tmethod: \"POST\",\n\t\t\theaders: {\n\t\t\t\t\"X-CSRFToken\": getCookie(\"csrftoken\"),\n\t\t\t},\n\t\t\tbody: formData,\n\t\t});\n\n\t\tif (!response.ok) return;\n\n\t\tconst data = await response.json();\n\n\t\tdocument.querySelectorAll(`.lineup-votes[data-vote-url=\"${url}\"]`).forEach(box => {\n\t\t\tconst count = box.querySelector(\".likes-count\");\n\n\t\t\tcount.textContent = data.likes;\n\t\t\tcount.classList.remove(\"bump-positive\", \"bump-negative\");\n\t\t\tvoid count.offsetWidth;\n\n\t\t\tcount.classList.add(\n\t\t\t\tdata.user_vote === -1\n\t\t\t\t\t? \"bump-negative\"\n\t\t\t\t\t: \"bump-positive\"\n\t\t\t);\n\n\t\t\tbox.querySelectorAll(\".vote-btn\").forEach(btn => {\n\t\t\t\tbtn.classList.remove(\"active\");\n\t\t\t});\n\n\t\t\tif (data.user_vote === 1) {\n\t\t\t\tbox.querySelector(\".vote-up\")?.classList.add(\"active\");\n\t\t\t}\n\t\t\tif (data.user_vote === -1) {\n\t\t\t\tbox.querySelector(\".vote-down\")?.classList.add(\"active\");\n\t\t\t}\n\t\t});\n\t});\n\n\t/* =========================\n\t\tCarousel\n\t========================= */\n\tfunction initLineupSlider(slider) {\n\t\tconst track = slider.querySelector(\".lineup-track\");\n\t\tif (!track) return;\n\t\tconst slides = slider.querySelectorAll(\".lineup-slide\");\n\t\tconst prevBtn = slider.querySelector(\".slider-prev\");\n\t\tconst nextBtn = slider.querySelector(\".slider-next\");\n\n\t\tlet index = 0;\n\t\tconst maxIndex = slides.length - 1;\n\n\t\tfunction updateSlider() {\n\t\t\ttrack.style.transform = `translateX(-${index * 100}%)`;\n\t\t\tif (prevBtn) {\n\t\t\t\tprevBtn.classList.toggle(\"disabled\", index === 0);\n\t\t\t}\n\t\t\tif (nextBtn) {\n\t\t\t\tnextBtn.classList.toggle(\"disabled\", index === maxIndex);\n\t\t\t}\n\t\t}\n\n\t\tif (nextBtn) {\n\t\t\tnextBtn.addEventListener(\"click\", event => {\n\t\t\t\tevent.stopPropagation();\n\t\t\t\tif (index < maxIndex) {\n\t\t\t\t\tindex++;\n\t\t\t\t\tupdateSlider();\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t\tif (prevBtn) {\n\t\t\tprevBtn.addEventListener(\"click\", event => {\n\t\t\t\tevent.stopPropagation();\n\t\t\t\tif (index > 0) {\n\t\t\t\t\tindex--;\n\t\t\t\t\tupdateSlider();\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\n\t\tupdateSlider();\n\t}\n\n\tdocument.querySelectorAll(\".lineup-media\").forEach(initLineupSlider);\n\n\t/* =========================\n\t\tLINEUP FULLSCREEN\n\t========================= */\n\tconst lineupModal = document.querySelector(\"#lineupModal\");\n\tconst lineupModalInner = lineupModal?.querySelector(\".lineup-modal-inner\");\n\tconst lineupModalClose = lineupModal?.querySelector(\"